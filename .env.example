# ============================================================
# GLM-OCR Production Server — Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
ENABLE_DOCS=true              # set false in production

# --- Auth ---
ENABLE_AUTH=false             # set true to enforce API key checks
API_KEYS=your-secret-key-1,your-secret-key-2

# --- Rate limiting ---
RATE_LIMIT_REQUESTS=60        # requests per window per IP
RATE_LIMIT_WINDOW=60          # window size in seconds

# --- File upload ---
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.doc,.docx

# --- GLM-OCR backend (vLLM / SGLang / MaaS) ---
OCR_MODE=selfhosted            # selfhosted | maas
OCR_API_HOST=192.168.90.10
OCR_API_PORT=8888
OCR_API_SCHEME=http
OCR_API_KEY=                   # required for MaaS (open.bigmodel.cn)
OCR_MODEL=zai-org/GLM-OCR     # model name as served by vLLM
OCR_ENABLE_LAYOUT=true         # set false if torch not installed locally
OCR_CONNECT_TIMEOUT=30
OCR_REQUEST_TIMEOUT=300

# --- Output ---
OUTPUT_FORMAT=both             # json | markdown | both

# --- CORS ---
CORS_ORIGINS=*                 # restrict in production, e.g. https://yourdomain.com

# --- Async task queue (optional) ---
USE_TASK_QUEUE=True
REDIS_URL=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=2       # max parallel tasks per worker
CELERY_WORKER_MAX_MEMORY_KB=512000 # ~500 MB, worker auto-restarts if exceeded
CELERY_RESULT_EXPIRES=3600         # seconds to keep results in Redis (1h)
CELERY_TASK_TIME_LIMIT=600         # hard kill after 10 min
CELERY_TASK_SOFT_TIME_LIMIT=540    # graceful timeout after 9 min
