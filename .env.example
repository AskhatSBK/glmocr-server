# ============================================================
# GLM-OCR Production Server (RunPod branch) — Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
ENABLE_DOCS=true              # set false in production

# --- Auth ---
ENABLE_AUTH=false             # set true to enforce API key checks
API_KEYS=your-secret-key-1,your-secret-key-2

# --- Rate limiting ---
RATE_LIMIT_REQUESTS=60        # requests per window per IP
RATE_LIMIT_WINDOW=60          # window size in seconds

# --- File upload ---
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.doc,.docx

# --- RunPod serverless backend ---
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/<your-endpoint-id>
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_TIMEOUT=300            # seconds to wait for job completion

# --- Output ---
OUTPUT_FORMAT=both             # json | markdown | both

# --- CORS ---
CORS_ORIGINS=*                 # restrict in production, e.g. https://yourdomain.com
