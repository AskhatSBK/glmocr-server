# ============================================================
# GLM-OCR Production Server — Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
ENABLE_DOCS=true              # set false in production

# --- Auth ---
# Comma-separated API keys. Leave empty to disable auth (dev only).
API_KEYS=your-secret-key-1,your-secret-key-2

# --- Rate limiting ---
RATE_LIMIT_REQUESTS=60        # requests per window per IP
RATE_LIMIT_WINDOW=60          # window size in seconds

# --- File upload ---
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.doc,.docx

# --- GLM-OCR backend (vLLM / SGLang / MaaS) ---
OCR_API_HOST=localhost
OCR_API_PORT=8080
OCR_API_SCHEME=http
OCR_API_KEY=                  # required for MaaS (open.bigmodel.cn)
OCR_CONNECT_TIMEOUT=30
OCR_REQUEST_TIMEOUT=300

# --- Output ---
OUTPUT_FORMAT=both             # json | markdown | both

# --- CORS ---
CORS_ORIGINS=*                 # restrict in production, e.g. https://yourdomain.com

# --- Async task queue (optional) ---
USE_TASK_QUEUE=false
REDIS_URL=redis://localhost:6379/0
